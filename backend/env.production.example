# ============================================
# TriLink Backend - Production Environment
# ============================================
# Copy this file to .env.production and fill in your values
# DO NOT commit .env.production to version control!

# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb+srv://omarbek9156_db_user:n6RjWPfC0gxUIbxS@trilink.sd1ppwj.mongodb.net/trilink?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Generate new strong secrets for production!
# Use: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_STRONG_SECRET_MIN_64_CHARS_FOR_PRODUCTION_USE_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=CHANGE_THIS_TO_STRONG_SECRET_MIN_64_CHARS_FOR_PRODUCTION_USE_OPENSSL_RAND_BASE64_64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
# Update with your production frontend URL(s)
# For multiple origins, separate with commas (no spaces)
# IMPORTANT: Include both with and without www if you use both
CORS_ORIGIN=https://trilink.me,https://www.trilink.me
# Or for single origin:
# CORS_ORIGIN=https://trilink.me

# Logging
LOG_LEVEL=info

# Redis Configuration (Required for production)
REDIS_URL=redis://localhost:6379
# Or for Redis with password:
# REDIS_URL=redis://:password@host:6379
# Or for Redis Cluster:
# REDIS_URL=redis://host1:6379,redis://host2:6379

# Socket.io Connection Limits
SOCKET_MAX_CONNECTIONS_PER_USER=5
SOCKET_MAX_CONNECTIONS_PER_COMPANY=100
SOCKET_MAX_CONNECTIONS_PER_IP=10

# AWS S3 Configuration (Required for file uploads)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=trilink-production-bucket

# Email Configuration
# Option 1: SendGrid (Recommended)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
EMAIL_FROM=noreply@trilink.me
EMAIL_FROM_NAME=TriLink Platform

# Option 2: SMTP (Alternative to SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for email links and redirects)
FRONTEND_URL=https://trilink.me

# Frontend Dist Path (if different from default)
# Only set this if frontend is in a non-standard location
# FRONTEND_DIST_PATH=/var/www/vhosts/trilink.me/httpdocs/frontend/dist

# Payment Gateway Configuration
# Stripe
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# PayPal
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_ENVIRONMENT=production
PAYPAL_WEBHOOK_SECRET=YOUR_PAYPAL_WEBHOOK_SECRET

# AI Configuration
AI_ENABLED=true

# Swagger Documentation (Optional - disable in production for security)
ENABLE_SWAGGER=false
