# Frontend Production Environment Variables
# Copy this to .env.production and update values

# API Base URL - Update to your production backend URL
# If backend is on same domain: https://trilink.me/api
# If backend is on subdomain: https://api.trilink.me/api
VITE_API_BASE_URL=https://trilink.me/api

# App Configuration
VITE_APP_NAME=TriLink
VITE_APP_VERSION=1.0.0

# Sentry Error Tracking (Optional)
VITE_ENABLE_SENTRY=true
VITE_SENTRY_DSN=your-sentry-dsn-here
