    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/leaflet": "^1.9.8",
    "axios": "^1.6.2",
    "cookie-parser": "^1.4.7",
    "leaflet": "^1.9.4",
